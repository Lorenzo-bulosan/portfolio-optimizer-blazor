@page "/portfolio"
@using PortfolioOptimizer.Data;
@using PortfolioOptimizer.Services
@using PortfolioOptimizer.Services.Interfaces
@inject IOptimizerService OptimizerService
@using Microsoft.AspNetCore.Components.Forms

@rendermode InteractiveServer

<h3>Modern Portfolio Theory (MPT) Portfolio Optimizer</h3>

<InputFile OnChange="HandleFile" accept=".csv" />

@if (Stock != null)
{
    <h4>@Stock.Name Metrics</h4>
    <ul>
        <li><b>Price Rows:</b> @Stock.Prices.Count</li>
        <li><b>Annualized Return:</b> @AnnualizedReturn:P2</li>
        <li><b>Volatility:</b> @AnnualizedVolatility:P2</li>
        <li><b>Sharpe Ratio:</b> @SharpeRatio:F2</li>
    </ul>
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Date</th>
                <th>Open</th>
                <th>Close</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var price in Stock.Prices.Take(20))
            {
                <tr>
                    <td>@price.Date.ToString("yyyy-MM-dd")</td>
                    <td>@price.Open</td>
                    <td>@price.Close</td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(Error))
{
     <div class="alert alert-danger">@Error</div>
}

@code {
    public Stock? Stock { get; set; }
    public string Error { get; set; } = string.Empty;
    public decimal AnnualizedReturn { get; set; }
    public decimal AnnualizedVolatility { get; set; }
    public decimal SharpeRatio { get; set; }

    private async Task HandleFile(InputFileChangeEventArgs e)
    {

        Error = "";
        var file = e.File;
        if (file == null)
        {
            Error = "No file selected.";
            return;
        }
        try
        {
            using var stream = file.OpenReadStream();

            // Todo: Handle large files with a limit
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();

            // Todo change this so it accepts content instead of the stream
            Stock = FileUtils.ParseCsvSingleStock(content);
            if (Stock.Prices.Count > 1)
            {
                var stockMetrics = OptimizerService.CalculateStockMetrics(Stock);
                AnnualizedReturn = stockMetrics.AnnualReturn;
                AnnualizedVolatility = stockMetrics.AnnualVolatility;
                SharpeRatio = stockMetrics.AnnualSharpeRatio;
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
    }
}