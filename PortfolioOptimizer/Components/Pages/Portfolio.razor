@* PortfolioOptimizer/Components/Pages/Portfolio.razor *@
@page "/portfolio"
@using PortfolioOptimizer.Data;
@using PortfolioOptimizer.Services
@using PortfolioOptimizer.Services.Interfaces
@inject IOptimizerService OptimizerService
@using Microsoft.AspNetCore.Components.Forms

@rendermode InteractiveServer

<h3>Modern Portfolio Theory (MPT) Portfolio Optimizer</h3>

<div class="mb-3">
    <label class="form-label">Upload Stock CSV Files:</label>
    <div class="form-text mb-2">
        You can upload either:
        <ul>
            <li>A single CSV file containing multiple stocks (with same date ranges)</li>
            <li>Multiple CSV files with one stock each (minimum 2 required with same date range)</li>
            <li>A combination of the above as long a it contains at least 2 different Stocks in total (same date range)</li>
        </ul>
    </div>
    <InputFile OnChange="HandleFiles" accept=".csv" multiple />
</div>

@if (Stocks.Any())
{
    <div class="card mb-3">
        <div class="card-header">
            <h5>Stock Portfolio Summary (@Stocks.Count stocks)</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Stock Name</th>
                            <th>Price Data Points</th>
                            <th>Date Range</th>
                            <th>Annual Return</th>
                            <th>Volatility</th>
                            <th>Sharpe Ratio</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var stock in Stocks)
                        {
                            <tr>
                                <td><strong>@stock.Name</strong></td>
                                <td>@stock.Prices.Count</td>
                                <td>
                                    @if (stock.Prices.Any())
                                    {
                                        var minDate = stock.Prices.Min(p => p.Date);
                                        var maxDate = stock.Prices.Max(p => p.Date);
                                        <small>@minDate.ToString("yyyy-MM-dd") to @maxDate.ToString("yyyy-MM-dd")</small>
                                    }
                                </td>
                                <td>@(StockMetrics.ContainsKey(stock.Name) ? StockMetrics[stock.Name].AnnualReturn.ToString("P2") : "N/A")</td>
                                <td>@(StockMetrics.ContainsKey(stock.Name) ? StockMetrics[stock.Name].AnnualVolatility.ToString("P2") : "N/A")</td>
                                <td>@(StockMetrics.ContainsKey(stock.Name) ? StockMetrics[stock.Name].AnnualSharpeRatio.ToString("F2") : "N/A")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mb-3">
        <button class="btn btn-primary" @onclick="CalculateOptimalAllocation" disabled="@(Stocks.Count < 2 || IsCalculating)">
            @if (IsCalculating)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                <text>Calculating...</text>
            }
            else
            {
                <text>Calculate Optimal Allocation</text>
            }
        </button>
    </div>

    @if (OptimalAllocation != null && OptimalAllocation.Any())
    {
        <div class="card">
            <div class="card-header">
                <h5>Optimal Portfolio Allocation</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <strong>Expected Annual Return:</strong> @PortfolioMetrics.AnnualReturn.ToString("P2")
                    </div>
                    <div class="col-md-4">
                        <strong>Portfolio Volatility:</strong> @PortfolioMetrics.AnnualVolatility.ToString("P2")
                    </div>
                    <div class="col-md-4">
                        <strong>Sharpe Ratio:</strong> @PortfolioMetrics.AnnualSharpeRatio.ToString("F2")
                    </div>
                </div>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Stock</th>
                            <th>Allocation</th>
                            <th>Weight</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var allocation in OptimalAllocation)
                        {
                            <tr>
                                <td>@allocation.Key</td>
                                <td>@allocation.Value.ToString("P2")</td>
                                <td>
                                    <div class="progress">
                                        <div class="progress-bar" role="progressbar" style="width: @(allocation.Value * 100)%">
                                            @allocation.Value.ToString("P2")
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@if (!string.IsNullOrEmpty(Error))
{
    <div class="alert alert-danger">@Error</div>
}

@code {
    public List<Stock> Stocks { get; set; } = new();
    public Dictionary<string, StockMetrics> StockMetrics { get; set; } = new();
    public Dictionary<string, decimal> OptimalAllocation { get; set; } = new();
    public PortfolioMetrics PortfolioMetrics { get; set; } = new();
    public string Error { get; set; } = string.Empty;
    public bool IsCalculating { get; set; } = false;

    private async Task HandleFiles(InputFileChangeEventArgs e)
    {
        Error = "";
        Stocks.Clear();
        StockMetrics.Clear();
        OptimalAllocation.Clear();

        try
        {
            var allStocks = new List<Stock>();
            var fileCount = e.FileCount;

            foreach (var file in e.GetMultipleFiles())
            {
                using var stream = file.OpenReadStream();
                using var reader = new StreamReader(stream);
                var content = await reader.ReadToEndAsync();

                var stocksFromFile = FileUtils.ParseCsv(content);

                // Filter stocks with sufficient data
                var validStocks = stocksFromFile.Where(s => s.Prices.Count > 1).ToList();
                allStocks.AddRange(validStocks);
            }

            // Remove duplicates by stock name (keep the first occurrence)
            var uniqueStocks = allStocks
                .GroupBy(s => s.Name)
                .Select(g => g.First())
                .ToList();

            // Validation logic
            if (fileCount > 1 && uniqueStocks.Count < 2)
            {
                Error = "When uploading multiple files, at least 2 stocks with sufficient price data are required.";
                return;
            }
            else if (fileCount == 1 && uniqueStocks.Count < 2)
            {
                Error = "When uploading a single file, it must contain at least 2 different stocks.";
                return;
            }

            // Validate date ranges are consistent
            if (!FileUtils.ValidateDateRanges(uniqueStocks))
            {
                Error = "All stocks must have the same date ranges for accurate portfolio optimization.";
                return;
            }

            Stocks = uniqueStocks;

            // Calculate metrics for each stock
            foreach (var stock in Stocks)
            {
                var stockMetrics = OptimizerService.CalculateStockMetrics(stock);
                StockMetrics[stock.Name] = stockMetrics;
            }
        }
        catch (Exception ex)
        {
            Error = $"Error processing files: {ex.Message}";
            Stocks.Clear();
            StockMetrics.Clear();
        }

        StateHasChanged();
    }

    private async Task CalculateOptimalAllocation()
    {
        if (Stocks.Count < 2) return;

        IsCalculating = true;
        Error = "";
        StateHasChanged();

        try
        {
            await Task.Delay(100); // Allow UI to update
            var result = OptimizerService.CalculateOptimalPortfolio(Stocks);
            OptimalAllocation = result.Allocations;
            PortfolioMetrics = result.Metrics;
        }
        catch (Exception ex)
        {
            Error = $"Error calculating optimal allocation: {ex.Message}";
        }
        finally
        {
            IsCalculating = false;
            StateHasChanged();
        }
    }
}