@* PortfolioOptimizer/Components/Pages/Portfolio.razor *@
@page "/"
@using PortfolioOptimizer.Data;
@using PortfolioOptimizer.Services
@using PortfolioOptimizer.Services.Interfaces
@inject IOptimizerService OptimizerService
@using Microsoft.AspNetCore.Components.Forms
@using System.Text
@inject IJSRuntime JSRuntime

@rendermode InteractiveServer

<h3>Modern Portfolio Theory (MPT) Portfolio Optimizer</h3>

<div class="mb-3">
    <label class="form-label">Upload Stock CSV Files:</label>
    <div class="form-text mb-2">
        You can upload either:
        <ul>
            <li>
                A single CSV file containing multiple stocks like: <a href="SampleFiles/AAPL.csv" download="AAPL.csv">AAPL.csv</a> and <a href="SampleFiles/ABBV.csv" download="ABBV.csv">ABBV.csv</a>
            </li>
            <li>
                Multiple CSV files with one stock each (minimum 2) like: <a href="SampleFiles/ContainsMultipleStocks.csv" download="ContainsMultipleStocks.csv">ContainsMultipleStocks.csv</a>
            </li>
            <li>A combination of the above as long a it contains at least 2 different Stocks in total</li>
        </ul>
        <p>
            <strong>Important:</strong> The CSV files should contain a "Date" column, "Name" column and a "Close" column with stock prices.
            If it contains a column called "Adj Close" this will be used for calculations instead of the Close price: <a href="SampleFiles/sample-with-multiple-stocks-from-2018-07-01_2025-07-15.csv" download="ContainsMultipleStocksWithAdjClose.csv">ContainsMultipleStocksWithAdjClose.csv</a>
        </p>
    </div>

    <label class="form-label">Key metrics will be calculated automatically based on the uploaded stock data:</label>
    <div class="form-text mb-2">
        With these you can
        <ul>
            <li>Select which stocks to include in the calculation of the optimal portfolio</li>
            <li>Set minimum and maximum weight constraints for each stock e.g limit one stock to 30% max to avoid over-reliance on one stock</li>
        </ul>
    </div>

    <div class="mb-2">
        <InputFile OnChange="HandleFiles" accept=".csv" multiple />
        @if (IsUploading)
        {
            <div class="d-flex align-items-center">
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                <span>Uploading files...</span>
            </div>
        }
    </div>

    @if (Stocks.Any())
    {
        <button class="btn btn-secondary btn-sm" @onclick="ClearAllStocks">
            Clear All Stocks
        </button>
    }
</div>

@if (Stocks.Any())
{
    <div class="card mb-3">
        <div class="card-header">
            <h5>Build Your Portfolio (@Stocks.Count stocks)</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Include</th>
                            <th>Stock Name</th>
                            <th>Weight</th>
                            <th>Price Data Points</th>
                            <th>Date Range</th>
                            <th>Annual Return</th>
                            <th>Volatility</th>
                            <th>Sharpe Ratio</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var stockDetails in Stocks)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" @bind="IncludedStocks[stockDetails.Stock.Name]" />
                                </td>
                                <td><strong>@stockDetails.Stock.Name</strong></td>
                                <td>
                                    <InputNumber @bind-Value="stockDetails.Weight" class="form-control" />
                                </td>
                                <td>@stockDetails.Stock.Prices.Count</td>
                                <td>
                                    @if (stockDetails.Stock.Prices.Any())
                                    {
                                        var minDate = stockDetails.Stock.Prices.Min(p => p.Date);
                                        var maxDate = stockDetails.Stock.Prices.Max(p => p.Date);
                                        <small>@minDate.ToString("yyyy-MM-dd") to @maxDate.ToString("yyyy-MM-dd")</small>
                                    }
                                </td>
                                <td>@(StockMetrics.ContainsKey(stockDetails.Stock.Name) ? StockMetrics[stockDetails.Stock.Name].AnnualReturn.ToString("P2") : "N/A")</td>
                                <td>@(StockMetrics.ContainsKey(stockDetails.Stock.Name) ? StockMetrics[stockDetails.Stock.Name].AnnualVolatility.ToString("P2") : "N/A")</td>
                                <td>@(StockMetrics.ContainsKey(stockDetails.Stock.Name) ? StockMetrics[stockDetails.Stock.Name].AnnualSharpeRatio.ToString("F2") : "N/A")</td>
                                <td>
                                    <button class="btn btn-danger btn-sm" @onclick="() => RemoveStock(stockDetails.Stock.Name)">Remove</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <button class="btn btn-secondary" @onclick="DistributeCustomWeightsEqually"
                    disabled="@(!IncludedStocks.Any())">
                <text>Distribute Equally</text>
            </button>
            
            <div class="card-body">
                <label>Initial Investment?</label>
                <InputNumber @bind-Value="InitialInvestmentValue" class="form-control" />
            </div>

            <div class="mb-3 my-2">
                <button class="btn btn-primary" @onclick="BuildCustomPortfolio"
                        disabled="@(Stocks.Where(s => IncludedStocks.ContainsKey(s.Stock.Name) && IncludedStocks[s.Stock.Name]).Count() < 2 || IsCalculatingOriginalPortfolio)">
                    @if (IsCalculatingOriginalPortfolio)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <text>Building Portfolio...</text>
                    }
                    else
                    {
                        <text>Build Portfolio</text>
                    }
                </button>
            </div>
        </div>
    </div>

    <!-- Historical Returns Chart -->
    @if (PortfolioHistoricalReturns != null && PortfolioHistoricalReturns.Any() && StockHistoricalReturns != null && StockHistoricalReturns.Any())
    {
        <div class="row mb-3">
            <div class="col-10">
                <h6>Historical Returns Comparison</h6>
                <p class="form-text mb-2">Comparison showing the historical dollar value growth of your portfolio vs each individual stock based on your initial investment of $@InitialInvestmentValue.ToString("N0")</p>
                <canvas id="lineChart"></canvas>
            </div>
        </div>
        <div class="card" id="original-portfolio-metrics">
            <div class="card-header">
                <h5>Portfolio Metrics (Pre-Optimization)</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <strong>Expected Annual Return:</strong> @OriginalPortfolioMetrics.AnnualReturn.ToString("F2")%
                    </div>
                    <div class="col-md-4">
                        <strong>Portfolio Volatility:</strong> @OriginalPortfolioMetrics.AnnualVolatility.ToString("F2")%
                    </div>
                    <div class="col-md-4">
                        <strong>Portfolio Sharpe Ratio:</strong> @OriginalPortfolioMetrics.AnnualSharpeRatio.ToString("F2")
                    </div>
                </div>
            </div>
        </div>
        <div class="mb-3 mt-3">
            <button class="btn btn-primary" @onclick="BuildOptimalPortfolio"
                    disabled="@(Stocks.Where(s => IncludedStocks.ContainsKey(s.Stock.Name) && IncludedStocks[s.Stock.Name]).Count() < 2 || IsCalculatingOptimalPortfolio)">
                @if (IsCalculatingOptimalPortfolio)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    <text>Optimizing Portfolio...</text>
                }
                else
                {
                    <text>Optimize Portfolio</text>
                }
            </button>
        </div>
    }

    @if (ShowOptimalPortfolio)
    {
        <div class="card mt-3">
            <div class="card-header">
                <h5>Portfolio Metrics (Optimized)</h5>
            </div>
            <div class="card-body" id="optimal-portfolio-metrics">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <strong>Expected Annual Return:</strong> @OptimalPortfolioMetrics.AnnualReturn.ToString("P2")
                    </div>
                    <div class="col-md-4">
                        <strong>Portfolio Volatility:</strong> @OptimalPortfolioMetrics.AnnualVolatility.ToString("P2")
                    </div>
                    <div class="col-md-4">
                        <strong>Portfolio Sharpe Ratio:</strong> @OptimalPortfolioMetrics.AnnualSharpeRatio.ToString("F2")
                    </div>
                </div>

                <!-- Pie Chart -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6>Portfolio Allocation</h6>
                        <p class="form-text mb-2">Optimal distribution for maximum sharpe ratio while minimizing risk.</p>
                        <canvas id="pieChart"></canvas>
                    </div>
                    <div class="col-md-6">
                        <p class="form-text mb-2">These are the optimal weights for your stocks. You can add min/max constraints for each stock and recalculate the optimal portfolio e.g at least 5% for stock "ABC".'</p>
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Stock</th>
                                    <th>Allocation</th>
                                    <th>Min %</th>
                                    <th>Max %</th>
                                    <th>Optimal Weight</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var stock in StocksForOptimalPortfolio)
                                {
                                    <tr>
                                        <td>@stock.Stock.Name</td>
                                        <td>
                                            <div class="progress">
                                                <div class="progress-bar" role="progressbar" style="width:@(stock.OptimalWeight * 100)%"></div>
                                            </div>
                                        </td>
                                        <td><InputNumber @bind-Value=@stock.WeightConstraint.MinWeight class="form-control" /></td>
                                        <td><InputNumber @bind-Value=@stock.WeightConstraint.MaxWeight class="form-control" /></td>
                                        <td>@stock.OptimalWeight.ToString("P2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger">@Error</div>
    }

    @if (!string.IsNullOrEmpty(SuccessMessage) && string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-success">@SuccessMessage</div>
    }
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>
<script src="js/portfolio-charts.js"></script>

@code {
    public List<StockDetails> Stocks { get; set; } = new();
    public List<StockDetails> StocksForOptimalPortfolio { get; set; } = new();
    public Dictionary<string, StockMetrics> StockMetrics { get; set; } = new();
    public bool ShowOptimalPortfolio { get; set; } = new();
    public PortfolioMetrics OriginalPortfolioMetrics { get; set; } = new();
    public PortfolioMetrics OptimalPortfolioMetrics { get; set; } = new();
    public string Error { get; set; } = string.Empty;
    public string SuccessMessage { get; set; } = string.Empty;
    public bool IsCalculatingOriginalPortfolio { get; set; } = false;
    public bool IsCalculatingOptimalPortfolio { get; set; } = false;
    public bool IsUploading { get; set; } = false;
    public Dictionary<string, bool> IncludedStocks { get; set; } = new();
    public List<ChartDataPoint> PortfolioHistoricalReturns { get; set; } = new();
    public List<ChartDataPoint> OptimalPortfolioHistoricalReturns { get; set; } = new();
    public Dictionary<string, List<ChartDataPoint>> StockHistoricalReturns { get; set; } = new();
    public string OriginalPortfolioElementId { get; set; } = "original-portfolio-metrics";
    public string OptimalPortfolioElementId { get; set; } = "optimal-portfolio-metrics";
    public decimal InitialInvestmentValue { get; set; } = 1000m;

    private async Task HandleFiles(InputFileChangeEventArgs e)
    {
        IsUploading = true;
        Error = "";
        ShowOptimalPortfolio = false;

        // Clear previous portfolio data to prevent old optimal portfolio from showing in charts
        PortfolioHistoricalReturns.Clear();
        OptimalPortfolioHistoricalReturns.Clear();
        StockHistoricalReturns.Clear();

        try
        {
            var newStocks = new List<StockDetails>();
            var fileCount = e.FileCount;
            const long maxStreamSize = 512 * 1024 * 1024; // 512MB

            foreach (var file in e.GetMultipleFiles())
            {
                // Size pre-checks
                if (file.Size > maxStreamSize)
                {
                    Error = $"File '{file.Name}' exceeds the maximum supported size of 512MB.";
                    return;
                }

                using var stream = file.OpenReadStream(maxAllowedSize: maxStreamSize);
                var stocksFromFile = await FileUtils.ParseCsvFromStreamAsync(stream);

                var validStocks = stocksFromFile.Where(s => s.Prices.Count > 1).ToList();
                foreach (var stock in validStocks)
                {
                    // Check if stock already exists
                    if (!Stocks.Any(s => s.Stock.Name == stock.Name))
                    {
                        newStocks.Add(new StockDetails
                        {
                            Stock = stock,
                            WeightConstraint = new WeightConstraint
                            {
                                MinWeight = 0.0m,
                                MaxWeight = 100.0m
                            }
                        });
                    }
                }
            }

            // Merge with existing stocks, avoiding duplicates
            var existingStockNames = Stocks.Select(s => s.Stock.Name).ToHashSet();
            var uniqueNewStocks = newStocks.Where(s => !existingStockNames.Contains(s.Stock.Name)).ToList();

            if (uniqueNewStocks.Any())
            {
                Stocks.AddRange(uniqueNewStocks);

                // Add to selected stocks (selected by default)
                foreach (var stockDetails in uniqueNewStocks)
                {
                    IncludedStocks[stockDetails.Stock.Name] = true;
                    stockDetails.WeightConstraint.MinWeight = 0.0m;
                    stockDetails.WeightConstraint.MaxWeight = 100.0m;
                }

                // Calculate metrics for new stocks
                foreach (var stockDetails in uniqueNewStocks)
                {
                    var stockMetrics = OptimizerService.CalculateStockMetrics(stockDetails.Stock);
                    StockMetrics[stockDetails.Stock.Name] = stockMetrics;
                }

                // Recalculate equal weights as there's more stocks now less weights for everyone
                DistributeCustomWeightsEqually();
            }

            // Validate minimum stock requirement
            if (Stocks.Count < 2)
            {
                Error = "At least 2 stocks with sufficient price data are required for portfolio optimization.";
                return;
            }

            if (!uniqueNewStocks.Any())
            {
                Error = "No new stocks were added. All stocks from the uploaded files already exist in the portfolio.";
            }
        }
        catch (Exception ex)
        {
            Error = $"Error processing files: {ex.Message}";
        }
        finally
        {
            IsUploading = false;
            StateHasChanged();
        }
    }

    private void ClearAllStocks()
    {
        Stocks.Clear();
        StockMetrics.Clear();
        ShowOptimalPortfolio = false;
        IncludedStocks.Clear();

        OriginalPortfolioMetrics = new();
        OptimalPortfolioMetrics = new();

        // Clear all chart data
        PortfolioHistoricalReturns.Clear();
        OptimalPortfolioHistoricalReturns.Clear();
        StockHistoricalReturns.Clear();

        Error = string.Empty;
        SuccessMessage = string.Empty;
        StateHasChanged();
    }

    private void RemoveStock(string name)
    {
        var stockToRemove = Stocks.FirstOrDefault(s => s.Stock.Name == name);
        if (stockToRemove != null)
        {
            Stocks.Remove(stockToRemove);
        }
        IncludedStocks.Remove(name);
        StockMetrics.Remove(name);
        ShowOptimalPortfolio = false;

        // Clear chart data when removing stocks to prevent stale data
        PortfolioHistoricalReturns.Clear();
        OptimalPortfolioHistoricalReturns.Clear();
        StockHistoricalReturns.Clear();

        StateHasChanged();
    }

    private void DistributeCustomWeightsEqually()
    {
        if (Stocks.Count < 2)
        {
            Error = "At least 2 stocks are required to distribute weights.";
            return;
        }
        // Distribute weights equally among selected stocks
        var selectedStocks = Stocks.Where(s => IncludedStocks.ContainsKey(s.Stock.Name) && IncludedStocks[s.Stock.Name]).ToList();

        if (selectedStocks.Count == 0)
        {
            Error = "At least 1 stock must be selected to distribute weights.";
            return;
        }

        // First, reset all weights to 0
        foreach (var stockDetails in Stocks)
        {
            stockDetails.Weight = 0m;
        }

        // Calculate equal weight and handle rounding to ensure total is exactly 100%
        var baseWeight = Math.Floor(100.0m / selectedStocks.Count * 100) / 100; // Round down to 2 decimal places
        var remainder = 100.0m - (baseWeight * selectedStocks.Count);

        // Distribute base weight to all selected stocks
        foreach (var stockDetails in selectedStocks)
        {
            stockDetails.Weight = baseWeight;
        }

        // Distribute the remainder (due to rounding) to the first few stocks
        var remainderCents = (int)(remainder * 100);
        for (int i = 0; i < remainderCents && i < selectedStocks.Count; i++)
        {
            selectedStocks[i].Weight += 0.01m;
        }

        Error = string.Empty;
        SuccessMessage = "Redistributed weights equally! But you can change it how ever you want as long as it totals 100%";
        StateHasChanged();
    }

    private List<StockDetails> GetSelectedStocksAndValidate(List<StockDetails> stockDetailsList)
    {
        var emptyStocks = new List<StockDetails>();

        // Filter to selected stocks
        var selectedStocks = stockDetailsList.Where(s => IncludedStocks.ContainsKey(s.Stock.Name) && IncludedStocks[s.Stock.Name]).ToList();

        if (selectedStocks.Count < 2)
        {
            Error = "At least 2 stocks are required for portfolio optimization.";
            return emptyStocks;
        }

        // Check if user defined weights are valid
        var totalUserDefinedWeights = selectedStocks.Sum(s => s.Weight);
        if (totalUserDefinedWeights != 100.0m)
        {
            Error = $"Weight allocation are not feasible: sum of weights ({totalUserDefinedWeights:F1}%) does not equal 100%.";
            return emptyStocks;
        }

        // check that user defined weights are not negative or over 100%
        foreach (var stockDetails in selectedStocks)
        {
            if (stockDetails.Weight < 0 || stockDetails.Weight > 100)
            {
                Error = $"Invalid weight for {stockDetails.Stock.Name}: weight must be between 0% and 100%.";
                return emptyStocks;
            }
        }

        // Validate date ranges for selected stocks only
        var (isValid, failingStocks) = FileUtils.ValidateDateRanges(selectedStocks.Select(s => s.Stock).ToList());
        if (!isValid)
        {
            Error = $"The following stocks do not have matching date ranges: {string.Join(", ", failingStocks)}. Please select a different combination or upload files with matching date ranges.";
            IsCalculatingOriginalPortfolio = false;
            StateHasChanged();
            return emptyStocks;
        }

        StateHasChanged();
        return selectedStocks;
    }

    private void CalculateHistoricalReturns(List<Stock> selectedStocks, Dictionary<string, decimal> weights)
    {
        // Calculate historical returns for charts using initial investment value
        PortfolioHistoricalReturns = OptimizerService.CalculatePortfolioHistoricalReturns(
            selectedStocks,
            weights,
            InitialInvestmentValue);

        StockHistoricalReturns = OptimizerService.CalculateStockHistoricalReturns(selectedStocks, InitialInvestmentValue);

        StateHasChanged();
    }

    private async Task BuildCustomPortfolio()
    {
        ShowOptimalPortfolio = false;
        OptimalPortfolioHistoricalReturns.Clear();
        IsCalculatingOriginalPortfolio = true;
        var selectedStocks = GetSelectedStocksAndValidate(Stocks);
        StateHasChanged();

        // Allow time for UI to update before calculations
        await Task.Delay(500);

        if (selectedStocks.Count < 2)
        {
            IsCalculatingOriginalPortfolio = false;
            PortfolioHistoricalReturns.Clear();
            StockHistoricalReturns.Clear();
            return; // Validation already set the error message
        }

        // Get user-defined weights
        var userDefinedWeights = selectedStocks.ToDictionary(
                    kvp => kvp.Stock.Name,
                    kvp => kvp.Weight / 100m // Convert to decimal
                );

        var result = OptimizerService.CalculatePortfolioMetrics(selectedStocks);
        OriginalPortfolioMetrics = result.Metrics;

        // Caculate returns for selected stocks and user defined weights
        CalculateHistoricalReturns(
            selectedStocks.Select(s=>s.Stock).ToList(),
            userDefinedWeights
        );

        // Render charts after calculation
        await RenderHistoricalReturnsChart();
        IsCalculatingOriginalPortfolio = false;
        Error = string.Empty;
        SuccessMessage = string.Empty;

        // Build separate object for optimal portfolio to not interfere with the original portfolio
        StocksForOptimalPortfolio = selectedStocks;

        await Task.Delay(500);
        StateHasChanged();

        // Scroll to original portfolio metrics
        await ScrollToElement(OriginalPortfolioElementId);
    }

    // Weight from allocation not from selected anymore
    private async Task BuildOptimalPortfolio()
    {
        IsCalculatingOptimalPortfolio = true;

        StateHasChanged();
        // Allow time for UI to update before calculations
        await Task.Delay(500);

        var selectedStocks = GetSelectedStocksAndValidate(StocksForOptimalPortfolio);

        if (selectedStocks.Count < 2)
        {
            IsCalculatingOptimalPortfolio = false;
            return; // Validation already set the error message
        }

        if (!ValidateWeightConstraints(selectedStocks))
        {
            IsCalculatingOptimalPortfolio = false;
            return; // Validation already set the error message
        }

        try
        {
            await Task.Delay(100); // Allow UI to update

            // Create weight constraints for optimization
            var constraints = new Dictionary<string, WeightConstraint>();
            selectedStocks.ForEach(s =>
            {
                constraints[s.Stock.Name] = new WeightConstraint
                {
                    MinWeight = s.WeightConstraint.MinWeight / 100.0m, // Convert to decimal
                    MaxWeight = s.WeightConstraint.MaxWeight / 100.0m  // Convert to decimal
                };
            });

            var result = OptimizerService.CalculateOptimalPortfolio(selectedStocks.Select(s => s.Stock).ToList(), constraints);

            // Update Stock details with optimal weights
            foreach (var stock in selectedStocks)
            {
                stock.OptimalWeight = result.Stocks[stock.Stock.Name].OptimalWeight;
            }

            OptimalPortfolioMetrics = result.Metrics;

            // Calculate historical returns for optimal portfolio using initial investment value
            OptimalPortfolioHistoricalReturns = OptimizerService.CalculatePortfolioHistoricalReturns(
                result.Stocks.Select(s => s.Value.Stock).ToList(),
                result.Stocks.ToDictionary(
                    kvp => kvp.Key,
                    kvp => kvp.Value.OptimalWeight
                ),
                InitialInvestmentValue
            );

            ShowOptimalPortfolio = true;

            // Render charts after calculation
            await Task.Delay(100);

            // Render allocation pie chart
            await RenderAllocationPieChart(selectedStocks);

            // Render line chart
            await RenderHistoricalReturnsChart();
        }
        catch (Exception ex)
        {
            Error = $"Error calculating optimal allocation: {ex.Message}";
        }
        finally
        {
            IsCalculatingOptimalPortfolio = false;
            StateHasChanged();

            await ScrollToElement(OptimalPortfolioElementId);
        }
    }

    private bool ValidateWeightConstraints(List<StockDetails> stocks)
    {
        var errorMessage = new StringBuilder();

        // Validate weight constraints
        foreach (var stockDetails in stocks)
        {
            if (stockDetails.WeightConstraint.MinWeight > stockDetails.WeightConstraint.MaxWeight)
            {
                errorMessage.AppendLine($"Invalid weight constraint for {stockDetails.Stock.Name}: minimum weight ({stockDetails.WeightConstraint.MinWeight}%) cannot be greater than maximum weight ({stockDetails.WeightConstraint.MaxWeight}%).");

            }
            if (stockDetails.WeightConstraint.MinWeight < 0)
            {
                errorMessage.AppendLine($"Invalid weight constraint for {stockDetails.Stock.Name}: minimum weight ({stockDetails.WeightConstraint.MinWeight}%) cannot be less than 0%).");

            }
        }

        // Check if constraints are feasible (sum of minimums <= 100%)
        var totalMinWeight = stocks.Sum(s => s.WeightConstraint.MinWeight);
        if (totalMinWeight > 100.0m)
        {
            errorMessage.AppendLine($"Weight constraints are not feasible: sum of minimum weights ({totalMinWeight:F1}%) exceeds 100%.");
        }

        Error = errorMessage.ToString();

        return Error == string.Empty;
    }

    private async Task RenderHistoricalReturnsChart()
    {
        try
        {
            // Ensure DOM updates are flushed
            await InvokeAsync(StateHasChanged);
            await Task.Delay(100); // Give the DOM time to render the canvas elements

            // Prepare data for line chart - values are now in dollars, not percentages
            var lineData = new
            {
                portfolio = PortfolioHistoricalReturns.Select(p => new
                {
                    x = p.Date.ToString("yyyy-MM-dd"),
                    y = (double)p.Value
                }).ToArray(),

                stocks = StockHistoricalReturns.ToDictionary(
                    kvp => kvp.Key,
                    kvp => kvp.Value.Select(p => new
                    {
                        x = p.Date.ToString("yyyy-MM-dd"),
                        y = (double)p.Value
                    }).ToArray()
                )
            };

            var optimalPortfoliolineData = new
            {
                optimalPortfolio = OptimalPortfolioHistoricalReturns.Select(p => new
                {
                    x = p.Date.ToString("yyyy-MM-dd"),
                    y = (double)p.Value
                }).ToArray()
            };

            // Render line chart
            await JSRuntime.InvokeVoidAsync("renderLineChart", "lineChart", lineData, optimalPortfoliolineData);
        }
        catch (Exception ex)
        {
            Error = $"Error rendering historical returns chart: {ex.Message}";
        }
    }

    private async Task RenderAllocationPieChart(List<StockDetails> stocks)
    {
        try
        {
            // Ensure DOM updates are flushed
            await InvokeAsync(StateHasChanged);
            await Task.Delay(100); // Give the DOM time to render the canvas elements

            // Prepare data for pie chart
            var pieData = stocks.Select(kvp => new
            {
                label = kvp.Stock.Name,
                value = (double)(kvp.OptimalWeight * 100)
            }).ToArray();

            // Render pie chart
            await JSRuntime.InvokeVoidAsync("renderPieChart", "pieChart", pieData);
        }
        catch (Exception ex)
        {
            Error = $"Error rendering allocation pie chart: {ex.Message}";
        }
    }

    private async Task ScrollToElement(string elementId)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("scrollToElement", elementId);
        }
        catch (Exception ex)
        {
            Error = $"Error scrolling to element: {elementId}";
        }
    }
}
